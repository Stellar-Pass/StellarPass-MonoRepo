{
  "name": "@stellar-pass/backend",
  "version": "1.0.0",
  "description": "Stellar Pass — NFT event ticketing API server",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "psql $DATABASE_URL -f src/db/schema.sql",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "@stellar-pass/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/postgres": "^5.2.2",
    "@fastify/rate-limit": "^9.1.0",
    "dotenv": "^16.4.5",
    "ed25519": "^0.0.5",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "nanoid": "^3.3.7",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "qrcode": "^1.5.4",
    "soroban-client": "^1.0.0",
    "stellar-sdk": "^12.1.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
